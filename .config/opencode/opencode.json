{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4-6",
  "small_model": "github-copilot/claude-haiku-4-5",
  "mcp": {
    "context7": {
      "enabled": true,
      "timeout": 30000,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser=msedge"
      ],
      "enabled": true,
      "type": "local"
    }
  }
}
