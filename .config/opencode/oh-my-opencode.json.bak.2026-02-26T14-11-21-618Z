{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "google_auth": false,
  "disabled_mcps": [],
  "agents": {
    "build": {
      "model": "anthropic/claude-opus-4-6"
    },
    "plan": {
      "model": "anthropic/claude-opus-4-6"
    },
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6"
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6"
    },
    "momus": {
      "model": "github-copilot/gpt-5.2"
    },
    "oracle": {
      "model": "github-copilot/gpt-5.2"
    },
    "librarian": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1"
    },
    "general": {
      "model": "anthropic/claude-opus-4-6"
    },
    "document-writer": {
      "model": "github-copilot/gemini-3-pro",
      "description": "Norwegian technical blog writer for AI and agentic development patterns",
      "prompt_append": "You are writing for a Norwegian technical blog about AI and agentic development patterns. Follow AGENTS.md exactly. Always write in Norwegian (bokmal) but keep technical terms in English (e.g., 'embedding', 'state machine', 'prompt engineering')."
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash"
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.3-codex"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-5"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3-pro"
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.3-codex",
      "reasoningEffort": "high"
    },
    "deep": {
      "model": "github-copilot/gpt-5.3-codex",
      "reasoningEffort": "medium"
    },
    "artistry": {
      "model": "github-copilot/gemini-3-pro"
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash"
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "providerConcurrency": {
      "anthropic": 3,
      "github-copilot": 5
    }
  }
}
