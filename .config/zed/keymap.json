[
  {
    "bindings": {
      "cmd-m": [
        "editor::ToggleComments",
        {
          "advance_downwards": false
        }
      ],
      "alt-enter": "editor::ToggleCodeActions",
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
      "cmd-0": "pane::ActivateLastItem"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // , -> go to end of file, append a new blank line, stay in insert
      ",": ["workspace::SendKeystrokes", "shift-g shift-a enter"],
      // ; -> go to top of file, insert at start of line
      ";": ["workspace::SendKeystrokes", "g g shift-i"]
    }
  }
]
