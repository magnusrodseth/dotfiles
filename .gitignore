.DS_Store
.env
rest-client
ignored
.config/ghostty/config.local
**/openai.sh
.config/github-copilot/**
**/stripe/config.toml
.config/StardewValley
.config/swiftpm
.config/zed/prompts
.config/zed/embeddings
.config/zed/conversations
.config/zed/settings_backup.json
.config/opencode/antigravity-accounts.json
# opencode dir is bun-managed locally (untracked package.json/bun.lock); never track npm lockfiles
.config/opencode/package-lock.json
.agents/
.agent/
.cursor/
.kiro/
.windsurf/
# Stray gcloud SDK fragment accidentally created in repo root; never track or stow
google-cloud-sdk/

# Claude Code runtime
.claude/backups/
.claude/cache/
.claude/debug/
.claude/file-history/
.claude/history.jsonl
.claude/ide/
.claude/paste-cache/
.claude/plans/
.claude/mcp-needs-auth-cache.json
.claude/plugins/blocklist.json
.claude/plugins/cache/
.claude/plugins/install-counts-cache.json
.claude/plugins/plugin-catalog-cache.json
.claude/plugins/known_marketplaces.json
.claude/plugins/marketplaces/
# Holds machine-specific absolute install paths (differs per machine/username)
.claude/plugins/installed_plugins.json
.claude/projects/
.claude/shell-snapshots/
.claude/stats-cache.json
.claude/statsig/
.claude/tasks/
.claude/telemetry/
.claude/todos/
.claude/transcripts/
.claude/usage-data/
.claude/image-cache/
.claude/sessions/
.claude/skills/*/scripts/__pycache__/
.claude/.last-cleanup
.claude/.last-update-result.json
# Atomic-write temp files (e.g. .last-update-result.json.tmp.<hash>)
.claude/*.tmp.*
# Daemon runtime state (control.key is sensitive) and job state
.claude/daemon/
.claude/daemon.log
.claude/jobs/

# Windsurf runtime (track User/settings.json only)
Library/Application Support/Windsurf/*
!Library/Application Support/Windsurf/User/
Library/Application Support/Windsurf/User/*
!Library/Application Support/Windsurf/User/settings.json

# MLflow
.config/mlflow/

# Copilot runtime
.config/.copilot/

# Cagent runtime
.config/cagent/

# uv package manager
.config/uv/uv-receipt.json

# Podman Desktop
Library/LaunchAgents/io.podman_desktop.PodmanDesktop.plist

# Podman machine runtime state (generated per-machine, not authored config)
.config/containers/podman/
.config/containers/podman-connections.json
.config/containers/podman-connections.json.lock

# App-generated LaunchAgents (not authored config; apps recreate these)
Library/LaunchAgents/com.dropbox.*
Library/LaunchAgents/com.valvesoftware.*

# Editor/tool backup files (git history is the backup)
# Covers dotted-suffix variants too (e.g. *.bak.pre-copilot, *.bak.2026-04-03)
*.bak
*.bak.*

# Fonts are installed via Homebrew cask (font-fira-code-nerd-font), not vendored
fonts/

# Raycast runtime
.config/raycast/extensions/node_modules
.config/raycast/extensions/**/*.js.map
# Compiled per-platform binaries (regenerated on extension install)
.config/raycast/extensions/**/compiled_raycast_rust/
.config/raycast/extensions/**/assets/webp/
# Color-picker wheel asset is regenerated (format swaps webp<->png) on update
.config/raycast/extensions/**/assets/rgb-color-wheel.*

# Google Cloud SDK credentials and runtime
.config/gcloud/

# Google Workspace CLI credentials
.config/gws/

# 1Password CLI (device ID is sensitive)
.config/op/

# ngrok (contains auth token)
.config/ngrok/ngrok.yml

# Context7 CLI (contains API credentials)
.config/context7/

# Notion CLI (ntn) runtime
.config/notion/

# hh-observe (contains Grafana session cookies for prod/test)
.config/hh-observe/

# Claude plugin sweep timestamp (machine churn)
.claude/plugins/.last_inuse_sweep
# Raycast vendored extension builds (regenerated on every Raycast update)
.config/raycast/extensions/**/*.js
# Extension manifests are regenerated on update (e.g. embedded language lists);
# the *.js code is already ignored, so these can't reconstruct an extension anyway.
.config/raycast/extensions/**/package.json

# Claude Code runtime session/team state
.claude/teams/

# Installed (non-dotfiles-authored) skill symlink
.claude/skills/playwriter
