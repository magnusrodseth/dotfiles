[user]
	email = magnus.rodseth@gmail.com
	name = magnusrodseth
	signingkey = /Users/magnus.rodseth/.ssh/id_ed25519.pub
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgSign = true
[gpg "ssh"]
	allowedSignersFile = /Users/magnus.rodseth/.ssh/allowed_signers
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
